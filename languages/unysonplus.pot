#: inc/helpers-shortcode-options.php:470
msgid "<p><strong>auto</strong> -\tDefault value. The background image contains its width and height.</p>\n\t\t\t\t\t\t\t\t<p><strong>cover</strong> - Scale the background image to be as large as possible so that the background area is completely covered by the background image. Some parts of the background image may not be in view within the background positioning area.</p>\n\t\t\t\t\t\t\t\t<p><strong>contain</strong> - Scale the image to the largest size such that both its width and its height can fit inside the content area.</p>\n\t\t\t\t\t\t\t\t<p><strong>custom</strong> - Counts for the width and height of the background image. i.e.:<br />\n\t\t\t\t\t\t\t\t400px - it counts for the width, and the height is set to auto.<br />\n\t\t\t\t\t\t\t\t300px 100px - the first sets the background image's width and the second sets the height. </p>"
msgstr ""

#: inc/helpers-shortcode-options.php:458
msgid "<p><strong>scroll</strong> - The background scrolls along with the page. This is default</p>\n\t\t\t\t\t\t\t\t\t<p><strong>fixed</strong> - The background is fixed with regard to the viewport.</p>\n\t\t\t\t\t\t\t\t\t"
msgstr ""

#: framework-customizations/theme/options/demo-2.php:554
